# Copy this to .env.local and fill in your values. Never commit .env.local.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional affiliate tags for purchase links. Leave blank for plain links.
# VITE_AMAZON_AFFILIATE_TAG=your-tag-20
# VITE_BOOKSHOP_AFFILIATE_ID=your-bookshop-id

# Optional PRH domain. Defaults to PRH.US. Set to PRH.MX for Mexico/LatAm
# (best for Costa Rica users), PRH.ESP for Spain.
# VITE_PRH_DOMAIN=PRH.MX

# ====== Server-side only (Netlify env vars) ======
# Do NOT put these in .env.local for production — they go in Netlify directly.
# Listed here for local dev with `netlify dev`:
# HARDCOVER_API_TOKEN=...
# ANTHROPIC_API_KEY=sk-ant-...
# PRH_API_KEY=...
